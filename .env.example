# ---------------------------------------------------------------------------
# Livin' — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` for local development and set the values
# below. In production, set the same variables in the Vercel project settings.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Supabase — content storage + admin auth
# ---------------------------------------------------------------------------
# Values live in Supabase → Project Settings → API.
# VITE_ prefix means they're inlined into the client bundle. The URL and
# anon key are safe to expose; the service_role key MUST stay server-only.

# https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — used from the browser for auth + public reads.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — server-only, bypasses row-level security.
# Rotate immediately if this ever leaks.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---------------------------------------------------------------------------
# Contact form — Web3Forms
# ---------------------------------------------------------------------------
# Sign up at https://web3forms.com, add the sender email, copy the key here.
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
