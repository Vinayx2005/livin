# ---------------------------------------------------------------------------
# Livin' — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` for local development and set the values
# below. In production, set the same variables in the Vercel project settings.
#
# All admin/CMS server functions read these at request time via process.env,
# so a dev-server restart is required after changing values locally.
# ---------------------------------------------------------------------------

# The password you type at /admin/login
ADMIN_PASSWORD=change-me

# A random string (>=16 characters) used to sign admin session tokens.
# Rotate this to invalidate every existing admin session.
AUTH_SECRET=please-generate-a-long-random-string

# GitHub — used by the CMS to commit content changes back to the repo.
# Fine-grained PAT with "Contents: Read and write" on the target repo:
#   https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# owner/repo where content lives (usually the same repo as the app)
GITHUB_REPO=Vinayx2005/livin

# Branch to commit to. Defaults to `main` if unset.
GITHUB_BRANCH=main

# ---------------------------------------------------------------------------
# Contact form — Web3Forms
# ---------------------------------------------------------------------------
# Public access key used by the /contact form to deliver submissions.
# Sign up at https://web3forms.com, add the sender email, copy the key here.
# Prefixed with VITE_ so it's inlined into the client bundle (Web3Forms keys
# are meant to be public; abuse is throttled server-side by the key owner).
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
